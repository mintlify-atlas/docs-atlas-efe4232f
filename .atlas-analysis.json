  "keyFeatures": [
    "Content-addressed SHA-256 hashing for incremental builds",
    "Declarative task configuration with multiple format support (JSON, JSONC, TOML, TypeScript)",
    "LLM-powered code generation with runner-agnostic CLI",
    "Lockfile tracking for team-wide consistency and CI builds",
    "Flexible glob patterns for source file matching",
    "Multiple CLI modes: force run, dry run, status check"
  ],
  "publicApiSurface": [
    "llmake - Run all tasks with changes",
    "llmake <task> - Run specific task",
    "llmake --force - Run regardless of hash state",
    "llmake --dry-run - Show what would run",
    "llmake --status - Show per-task change status",
    "llmake --init - Create starter config",
    "llmake --config <path> - Use specific config file",
